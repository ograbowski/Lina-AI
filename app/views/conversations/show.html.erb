
<div class="max-w-4xl mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold"><%= @conversation.title %></h1>
    <%= link_to "← Powrót", conversations_path, class: "text-blue-500 hover:underline" %>
  </div>

  <div class="bg-white border rounded-lg mb-6" style="height: 60vh; overflow-y: auto;" id="messages-container">
    <div class="p-4 space-y-4">
      <%= turbo_stream_from @conversation %>
      <div id="messages">
        <% @messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>
      </div>
    </div>
  </div>

  <%= render "messages/form", conversation: @conversation, new_message: @new_message %>
</div>

<script>
    function scrollToBottom() {
        const container = document.getElementById('messages-container');
        container.scrollTop = container.scrollHeight;
    }

    scrollToBottom();

    document.addEventListener('turbo:frame-render', scrollToBottom);
</script>