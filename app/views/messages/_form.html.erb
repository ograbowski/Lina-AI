<%= form_with model: [conversation, new_message],
              data: { turbo: true },
              class: "flex gap-2",
              id: "new-message-form" do |form| %>
  <%= form.text_field :content, placeholder: "Type in a message...",
                     class: "input flex-1 border rounded-lg p-3 placeholder:text-sm/6"%>
  <%= form.submit "Send", class: "btn-primary text-white text-sm/6 px-6 py-2 rounded-lg " %>

<% end %>
