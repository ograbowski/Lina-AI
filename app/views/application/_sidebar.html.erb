<div id="mobile-sidebar"
     data-sidebar-target="sidebar"
     data-turbo-permanent
     class="relative z-50 hidden">

  <div class="fixed inset-y-0 left-0 flex w-40 lg:w-64">
    <div
      data-sidebar-target="panel"
      class="relative flex w-full max-w-xs flex-1 -translate-x-full transition ease-in-out duration-300 transform">

      <div class="scrollbar bg-app flex grow flex-col gap-y-5 overflow-y-auto px-6 pb-4 shadow-lg border-r border-[#3F0071]">
        <div class="flex h-16 shrink-0 items-center justify-between">
          <img class="h-8 w-auto" src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500" alt="Your Company">
          <div
            data-sidebar-target="closeBtn"
            class="opacity-0 transition ease-in-out duration-300">
            <button type="button" data-action="click->sidebar#close" class="-mx-2.5 cursor-pointer">
              <span class="sr-only">Close sidebar</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 text-app hover:text-gray-200">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75"/>
              </svg>
            </button>
          </div>
        </div>
        <nav class="flex flex-1 flex-col">
          <ul role="list" class="flex flex-col gap-y-7 -mx-2">
            <li>
              <%= link_to conversations_path, data: { 'turbo-method' => :post }, class: "bg-[#10B981] hover:bg-[#059669] text-white group flex gap-x-3 rounded-lg p-2 px-2 text-sm/6  font-semibold rounded " do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/>
                </svg>
                New chat
              <% end %>
            </li>
          </ul>

          <%= render "sidebar_divider", text: "Chats" %>

          <ul role="list" class="flex flex-1 flex-col gap-y-7">
            <li>
              <ul role="list" class="-mx-2 space-y-1">
                <%= render "conversations/conversations", conversations: current_user.conversations.order(updated_at: :desc) %>
              </ul>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</div>