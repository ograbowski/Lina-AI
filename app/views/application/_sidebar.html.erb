<!-- Mobile overlay (lg:hidden) -->
<div id="mobile-sidebar"
     data-sidebar-target="sidebar"
     data-turbo-permanent
     class="relative z-50 lg:hidden hidden">

  <!-- Background overlay -->
  <div class="fixed inset-0 bg-gray-900/80" data-action="click->sidebar#close"></div>

  <div class="fixed inset-y-0 left-0 flex w-56">
    <div data-sidebar-target="panel"
         class="relative flex w-full max-w-xs flex-1 -translate-x-full transition ease-in-out duration-300 transform">

      <div class="scrollbar bg-app flex grow flex-col gap-y-5 overflow-y-auto px-6 pb-4 shadow-lg border-r border-[#3F0071]">
        <div class="flex h-16 shrink-0 items-center justify-between">
          <img class="h-8 w-auto" src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500" alt="Your Company">
          <div data-sidebar-target="closeBtn"
               class="opacity-0 transition ease-in-out duration-300">
            <button type="button" data-action="click->sidebar#close" class="-mx-2.5 cursor-pointer hover:text-[#E9DFFC]">
              <span class="sr-only">Close sidebar</span>
              <%= render "application/icons/in_right", icon_class: "size-6" %>
            </button>
          </div>
        </div>
        <nav class="flex flex-1 flex-col">
          <%= render "sidebar_content" %>
        </nav>
      </div>
    </div>
  </div>
</div>

<!-- Desktop sidebar (hidden lg:block) -->
<div id="desktop-sidebar"
     data-sidebar-target="desktopSidebar"
     data-turbo-permanent
     class="hidden lg:block">

  <div class="fixed inset-y-0 left-0 flex w-56 transform transition-transform duration-300 ease-in-out"
       data-sidebar-target="desktopPanel">

    <div class="scrollbar bg-app flex grow flex-col gap-y-5 overflow-y-auto px-6 pb-4 shadow-lg border-r border-[#3F0071]">
      <div class="flex h-16 shrink-0 items-center justify-between">
        <img class="h-8 w-auto" src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500" alt="Your Company">
        <div data-sidebar-target="desktopCloseBtn"
             class="opacity-100 transition ease-in-out duration-300">
          <button type="button" data-action="click->sidebar#close" class="-mx-2.5 cursor-pointer hover:text-[#E9DFFC]">
            <span class="sr-only">Close sidebar</span>
            <%= render "application/icons/in_right", icon_class: "size-6" %>
          </button>
        </div>
      </div>
      <nav class="flex flex-1 flex-col">
        <%= render "sidebar_content" %>
      </nav>
    </div>
  </div>
</div>