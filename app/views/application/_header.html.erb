<div class="sticky top-0 z-40 flex items-center justify-between gap-x-6 bg-[#2A004F] text-app px-4 py-4 shadow-xs sm:px-6">
  <button type="button" data-action="click->sidebar#open" class="-m-2.5 p-2.5 text-white cursor-pointer">
    <span class="sr-only">Open sidebar</span>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 hover:text-gray-200">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
    </svg>
  </button>

  <div class="flex gap-x-4 text-sm/6 font-medium">
    <div>
      <%= link_to "About lina", about_lina_path, class: "hover:underline underline-offset-2 decoration-1" %>
    </div>
    <div>
      <%= link_to "About dev", about_dev_path, class: "hover:underline underline-offset-2 decoration-1" %>
    </div>
  </div>

  <div>
    <%= link_to "Profile", profile_path, class: "hover:underline underline-offset-2 decoration-1" %>
  </div>
</div>